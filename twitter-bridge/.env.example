# Twitter
TWITTER_AUTH_TOKEN=           # 浏览器 F12 → Application → Cookies → twitter.com → auth_token
TWITTER_CT0=                  # 同页面 Cookies → ct0（csrf token，必需）
TWITTER_USERNAME=lxgy1024     # 你的 Twitter 用户名

# Bluesky
BLUESKY_HANDLE=lxgy1024.bsky.social
BLUESKY_APP_PASSWORD=         # Bluesky → Settings → App Passwords → 生成

# GitHub（用于同步后自动触发网站重建）
GITHUB_PAT=                   # GitHub → Settings → Developer settings → Personal access tokens → Fine-grained tokens → 创建 repo 权限 token
